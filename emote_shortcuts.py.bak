# ==========================================
# AUTO-GENERATED COMMANDS (DO NOT EDIT)
# ==========================================
# System automatically generates all command variants
SHORTCUT_EMOTES = {}

for command, emote_id in BASE_EMOTES.items():
    # Base command - check if it has a special default
    if command in SPECIAL_DEFAULTS:
        default_uid = SPECIAL_DEFAULTS[command]
    else:
        default_uid = None  # Will use DEFAULT_PLAYER_UIDS
    
    # Register base command: /p, /m18, /car, etc.
    SHORTCUT_EMOTES[f'/{command}'] = (emote_id, command.upper(), default_uid)
    
    # Register variant commands for each variant
    for variant_key, variant_uid in VARIANT_UIDS.items():
        # Creates: /p s, /p c, /m18 s, /m18 c, etc.
        SHORTCUT_EMOTES[f'/{command} {variant_key}'] = (
            emote_id, 
            f'{command.upper()} {variant_key.upper()}', 
            variant_uid
        )

# ==========================================
# 📋 USAGE EXAMPLES
# ==========================================
# 
# নতুন emote add করতে:
# BASE_EMOTES dictionary তে add করুন:
# 'dance': 909000099,
# 
# এটা automatically তৈরি করবে:
# /dance → DEFAULT_PLAYER_UIDS
# /dance s → 2303950929 (secret)
# /dance c → 13663048989 (crazy)
#
# নতুন variant add করতে:
# VARIANT_UIDS dictionary তে add করুন:
# 'v': 111222333,
#
# এটা automatically সব commands এ apply হবে:
# /p v → 111222333
# /m18 v → 111222333
# /car v → 111222333
